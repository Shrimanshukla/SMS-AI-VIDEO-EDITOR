# SMS Video Editor - Environment Variables Template
# Copy this file as .env and fill in your values

# ===== REQUIRED: AWS S3 Configuration =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET_NAME=sms-video-editor

# ===== REQUIRED: JWT Secret (for authentication) =====
# Generate with: openssl rand -base64 32 (or use auto-generated from setup)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# ===== Server Configuration =====
PORT=5000
NODE_ENV=production

# ===== Database =====
# SQLite path (Docker: ./data/sms-video-editor.db)
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=./data/sms-video-editor.db

# ===== Frontend Configuration =====
# (Used in Docker container)
VITE_API_URL=http://localhost:5000
